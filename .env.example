# Copy to `.env` on the server (do not commit real secrets).
# Restart the API after changing Razorpay variables.

MONGO_URI=
ACCESS_TOKEN_SECRET=

# Razorpay LIVE (production): use the key pair from Razorpay Dashboard > API Keys (Live mode).
# The user app must use the same RAZORPAY_KEY_ID in `magic/src/environments/environment.prod.ts` (or your CI inject).
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_live_key_secret_here
